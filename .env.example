# Desenvolvimento: deixe DATABASE_URL e Cloudinary vazios para usar SQLite e media local.
DEBUG=True
SECRET_KEY=alterar-para-uma-chave-segura
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Neon (usar a connection string pooled com sslmode=require)
DATABASE_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Segurança de produção
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
